---
import BaseLayout from "./BaseLayout.astro";
import TopBar from "../components/TopBar.astro";
import Hero from "../components/Hero/index.astro";
import About from "../components/About.astro";
import TechStrip from "../components/TechStrip.astro";
import ExperienceList from "../components/Experience/List.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import CursorGradient from "../components/islands/CursorGradient.tsx";
import BottomPanel from "../components/islands/BottomPanel.tsx";
import type { Translations } from "../i18n/types";
import type { Locale } from "../lib/site";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
---

<BaseLayout t={t} locale={locale}>
  <a href="#main" class="skip-link">{t.skipToContent}</a>

  <div class="relative min-h-screen">
    <CursorGradient client:idle />

    <TopBar t={t} locale={locale} />

    <main
      class="relative z-10 mx-auto w-full max-w-[760px] px-5 md:px-8"
      id="main"
    >
      <Hero t={t} />
      <About t={t} />
      <TechStrip t={t} />
      <ExperienceList t={t} locale={locale} />
      <Faq t={t} />
      <Footer t={t} />
    </main>
  </div>

  <BottomPanel client:idle topLabel={t.backToTop} />

  <script>
    import "../scripts/fade-on-scroll";
  </script>
</BaseLayout>
