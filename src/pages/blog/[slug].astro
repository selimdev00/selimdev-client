---
import { getCollection, type CollectionEntry } from "astro:content";
import WritingLayout from "../../layouts/WritingLayout.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import { site } from "../../lib/site";

export async function getStaticPaths() {
  const isProd = import.meta.env.PROD;
  const posts = await getCollection("posts", ({ data }) =>
    isProd ? !data.draft : true,
  );
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const wordCount = post.body.trim().split(/\s+/).length;
const minutes = Math.max(1, Math.round(wordCount / 220));
---

<WritingLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`${site.url}/blog/${post.slug}/`}
>
  <article class="post">
    <header class="mb-10 md:mb-12">
      <a
        href="/blog/"
        class="inline-flex items-center gap-1.5 text-[13px] text-gray-500 dark:text-gray-500 hover:text-sky-700 dark:hover:text-sky-200 transition-colors duration-300"
      >
        <span aria-hidden="true">&larr;</span>
        <span>Writing</span>
      </a>

      <h1
        class="mt-6 font-bold leading-[1.1] tracking-tight text-gray-900 dark:text-white"
        style="font-size: clamp(30px, 5.6vw, 44px);"
      >
        {post.data.title}
      </h1>

      <p
        class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-[12px] font-semibold uppercase tracking-[0.14em] text-gray-500 dark:text-gray-500"
      >
        <time datetime={post.data.pubDate.toISOString()}>
          {dateFormatter.format(post.data.pubDate)}
        </time>
        <span aria-hidden="true">·</span>
        <span>{minutes} min read</span>
        {
          post.data.updatedDate ? (
            <>
              <span aria-hidden="true">·</span>
              <span>
                Updated {dateFormatter.format(post.data.updatedDate)}
              </span>
            </>
          ) : null
        }
        {
          post.data.draft ? (
            <span class="rounded-sm border border-sky-500/40 px-1.5 py-0.5 text-sky-700 dark:text-sky-300 dark:border-sky-300/40 normal-case tracking-normal text-[11px] font-medium">
              draft
            </span>
          ) : null
        }
      </p>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="mt-16 md:mt-20 pt-10 border-t border-gray-200 dark:border-slate-800">
      <AuthorCard variant="outro" />
      <p class="mt-6 text-[13px]">
        <a
          href="/blog/"
          class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-500 hover:text-sky-700 dark:hover:text-sky-200 transition-colors duration-300"
        >
          <span aria-hidden="true">&larr;</span>
          <span>More posts</span>
        </a>
      </p>
    </footer>
  </article>
</WritingLayout>

<style is:global>
  .post-body {
    color: var(--ink-primary);
    font-size: 17px;
    line-height: 1.75;
    max-width: 68ch;
  }

  .post-body > * + * {
    margin-top: 1.25em;
  }

  .post-body h2 {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink-strong);
    margin-top: 2em;
    line-height: 1.3;
    letter-spacing: -0.005em;
  }

  .post-body h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--ink-strong);
    margin-top: 1.6em;
    line-height: 1.4;
  }

  .post-body a {
    color: var(--accent);
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 200ms var(--ease-out-quart);
  }

  .post-body a:hover {
    color: var(--accent-deep);
  }

  .post-body code {
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace;
    font-size: 0.9em;
    background: var(--code-bg);
    color: var(--code-fg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .post-body pre {
    background: var(--pre-bg, #0f172a);
    color: var(--pre-fg, #e2e8f0);
    padding: 1em 1.25em;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.55;
  }

  html.dark .post-body pre {
    background: var(--code-bg);
    color: var(--code-fg);
  }

  .post-body pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }

  .post-body blockquote {
    border-left: 1px solid var(--accent-line);
    padding-left: 1em;
    color: var(--ink-secondary);
    font-style: normal;
  }

  .post-body ul,
  .post-body ol {
    padding-left: 1.4em;
  }

  .post-body ul {
    list-style: disc;
  }

  .post-body ol {
    list-style: decimal;
  }

  .post-body img {
    border-radius: 6px;
    max-width: 100%;
    height: auto;
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--hr-line);
    margin: 2.5em 0;
  }
</style>
