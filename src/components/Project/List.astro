---
import { projects } from "../../data/projects";
import Item from "./Item.astro";
import FadeIn from "../FadeIn.astro";
import type { Translations } from "../../i18n/types";
import type { Locale } from "../../lib/site";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
---

<section id="projects" class="pt-4">
  <h2
    class="text-sm font-semibold uppercase tracking-widest dark:text-sky-400 text-sky-600 mb-8"
  >
    {t.projects}
  </h2>
  <ul class="flex flex-col gap-[45px] group/list">
    {
      projects.map((item) => (
        <FadeIn as="li" class="group/item">
          <Item item={item} t={t} locale={locale} />
        </FadeIn>
      ))
    }
  </ul>
</section>
