---
import { Icon } from "astro-icon/components";
import type { Locale } from "../../lib/site";

interface Props {
  current: Locale;
}

const { current } = Astro.props;

const items: { code: Locale; name: string; icon: string; href: string }[] = [
  {
    code: "en",
    name: "English",
    icon: "twemoji:flag-united-states",
    href: "/",
  },
  { code: "ru", name: "Русский", icon: "twemoji:flag-russia", href: "/ru/" },
];

const active = items.find((i) => i.code === current) ?? items[0];
---

<details class="relative w-full lang-switcher">
  <summary
    class="flex items-center justify-between rounded-xl border dark:border-white border-gray-500 py-2 px-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden"
  >
    <span>{active.name}</span>
    <span class="flex items-center gap-2">
      <Icon name={active.icon} />
      <Icon name="mdi:chevron-up" />
    </span>
  </summary>
  <div
    class="flex flex-col dark:bg-slate-800 bg-sky-100 rounded-xl absolute bottom-[calc(100%+10px)] w-full overflow-hidden shadow-sm z-20"
  >
    {
      items.map((item) => (
        <a
          href={item.href}
          class="py-2 px-4 cursor-pointer dark:hover:bg-slate-700 hover:bg-sky-200 flex items-center justify-between text-sm"
          aria-current={item.code === current ? "true" : undefined}
        >
          <span>{item.name}</span>
          <Icon name={item.icon} />
        </a>
      ))
    }
  </div>
</details>
