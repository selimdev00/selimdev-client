---
import { Icon } from "astro-icon/components";
import { TECH_GROUPS } from "../lib/site";
import type { Translations } from "../i18n/types";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="stack"
  class="py-10 md:py-14 scroll-mt-12"
  data-fade-on-scroll
>
  <SectionHeading label={t.technologies} />

  <p
    class="mt-7 text-[16px] md:text-[17px] leading-[1.75] text-gray-700 dark:text-gray-300 max-w-[62ch]"
  >
    {t.techLead}
  </p>

  <div class="mt-9 flex flex-col gap-7">
    {
      TECH_GROUPS.map((group) => (
        <div class="flex flex-col gap-2.5">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-gray-900 dark:text-white">
              {t.techGroups[group.key]}
            </span>
            <span class="text-gray-300 dark:text-gray-700" aria-hidden="true">
              ·
            </span>
            <span class="text-[11px] uppercase tracking-[0.14em] text-sky-700 dark:text-sky-300">
              {t.techMeta[group.key]}
            </span>
          </div>

          <ul class="flex flex-wrap gap-1.5">
            {group.items.map((tech) => (
              <li class="inline-flex items-center gap-1.5 rounded-md border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900/40 px-2.5 py-1 text-[13px] text-gray-700 dark:text-gray-200 hover:border-sky-700/40 dark:hover:border-sky-300/40 hover:text-sky-700 dark:hover:text-sky-200 transition-colors duration-300">
                <Icon
                  name={tech.icon}
                  class="text-[13px] text-gray-500 dark:text-gray-500"
                  aria-hidden="true"
                />
                <span>{tech.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
