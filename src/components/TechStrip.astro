---
import { PRIMARY_TECHS, SECONDARY_TECHS, AI_TOOLS } from "../lib/site";
import type { Translations } from "../i18n/types";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="stack"
  class="py-10 md:py-14 scroll-mt-12"
  data-fade-on-scroll
>
  <SectionHeading label={t.technologies} />

  <p
    class="mt-7 text-[16px] md:text-[17px] leading-[1.75] text-gray-700 dark:text-gray-300 max-w-[60ch]"
  >
    {
      PRIMARY_TECHS.map((tech, index) => (
        <>
          <span class="font-semibold text-gray-900 dark:text-white">
            {tech}
          </span>
          {index < PRIMARY_TECHS.length - 1 && (
            <span
              class="text-sky-700/50 dark:text-sky-300/40 mx-2"
              aria-hidden="true"
            >
              ·
            </span>
          )}
        </>
      ))
    }
  </p>

  <p
    class="mt-3 text-[14px] leading-[1.7] text-gray-500 dark:text-gray-500 max-w-[60ch]"
  >
    {SECONDARY_TECHS.join(" · ")}
  </p>

  <p
    class="mt-5 text-[14px] leading-[1.7] max-w-[60ch] flex flex-wrap items-baseline gap-x-2"
  >
    <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-700 dark:text-sky-300">
      {t.aiWorkflowLabel}
    </span>
    <span class="text-gray-700 dark:text-gray-300">
      {AI_TOOLS.join(" · ")}
    </span>
  </p>
</section>
