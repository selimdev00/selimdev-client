---
import Sidebar from "./Profile/Sidebar.astro";
import type { Translations } from "../i18n/types";
import type { Locale } from "../lib/site";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
---

<div
  id="mobile-menu"
  class="fixed inset-0 dark:bg-slate-950 bg-white z-30 hidden no-print"
  aria-hidden="true"
>
  <Sidebar t={t} locale={locale} variant="mobile" />
</div>

<script is:inline>
  (function () {
    var menu = document.getElementById("mobile-menu");
    if (!menu) return;

    function apply(open) {
      if (open) {
        menu.classList.remove("hidden");
        menu.removeAttribute("aria-hidden");
      } else {
        menu.classList.add("hidden");
        menu.setAttribute("aria-hidden", "true");
      }
    }

    document.addEventListener("menu-toggle", function (e) {
      apply(!!e.detail && e.detail.open);
    });
  })();
</script>
