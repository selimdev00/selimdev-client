---
import { Icon } from "astro-icon/components";
import { site, totalExperienceYears } from "../../lib/site";
import type { Translations } from "../../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const years = totalExperienceYears();
---

<section id="top" class="pt-12 pb-16 md:pt-20 md:pb-24">
  <div class="flex items-center gap-4 mb-10">
    <img
      src="/avatar-face.png"
      alt={`${site.ownerName} portrait`}
      width="56"
      height="56"
      loading="eager"
      decoding="async"
      class="rounded-full w-14 h-14 ring-1 ring-sky-600/30 dark:ring-sky-300/30"
    />
    <span class="flex items-center gap-2 text-[12px] font-medium uppercase tracking-[0.12em] text-sky-700 dark:text-sky-200">
      <span
        class="inline-block h-1.5 w-1.5 rounded-full bg-sky-600 dark:bg-sky-300"
        aria-hidden="true"></span>
      {t.available}
    </span>
  </div>

  <h1
    class="font-bold leading-[0.95] tracking-tight text-gray-900 dark:text-white"
    style="font-size: clamp(40px, 8vw, 64px);"
  >
    {t.website.title}
  </h1>

  <p
    class="mt-3 text-[16px] md:text-[17px] font-medium text-gray-700 dark:text-gray-300"
  >
    {t.website.subtitle}
    <span class="text-gray-400 dark:text-gray-600 mx-2" aria-hidden="true">·</span>
    <span class="text-sky-700 dark:text-sky-300 proof-value">{years}+</span>
    <span class="text-gray-500 dark:text-gray-500"> {t.yearsExperience}</span>
  </p>

  <p
    class="mt-6 max-w-[58ch] text-[16px] md:text-[17px] leading-[1.65] text-gray-600 dark:text-gray-400"
  >
    {t.website.description}
  </p>

  <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3">
    <a
      href={site.telegramUrl}
      target="_blank"
      rel="noopener"
      class="group inline-flex items-center gap-2 rounded-md bg-sky-700 dark:bg-sky-300 px-4 py-2.5 text-[14px] font-semibold text-white dark:text-slate-950 transition-[background-color,transform] duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] hover:bg-sky-800 dark:hover:bg-sky-200"
    >
      <Icon name="mdi:telegram" class="text-[16px]" />
      <span>{t.primaryCta}</span>
      <Icon
        name="mdi:arrow-right"
        class="text-[14px] transition-transform duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:translate-x-0.5"
      />
    </a>
    <a
      href={site.githubUrl}
      target="_blank"
      rel="noopener"
      class="group inline-flex items-center gap-2 text-[14px] font-semibold text-gray-700 dark:text-gray-300 hover:text-sky-700 dark:hover:text-sky-200 transition-colors duration-300"
    >
      <Icon name="mdi:github" class="text-[18px]" />
      <span>{t.githubCta}</span>
      <Icon
        name="mdi:arrow-top-right"
        class="text-[14px] transition-transform duration-300 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
      />
    </a>
  </div>
</section>
