---
import { Icon } from "astro-icon/components";
import type { Experience } from "../../data/experiences";
import type { Translations } from "../../i18n/types";
import type { Locale } from "../../lib/site";
import { formatMonthYear } from "../../lib/format";

interface Props {
  item: Experience;
  t: Translations;
  locale: Locale;
}

const { item, t, locale } = Astro.props;
const data = t.experienceItems[item.positionKey];
const fromLabel = formatMonthYear(item.from, locale);
const toLabel = item.to === "now" ? t.now : formatMonthYear(item.to, locale);
const isOngoing = item.to === "now";
---

<article
  class="group/item relative transition-opacity duration-300 group-hover/list:opacity-40 hover:!opacity-100 focus-within:!opacity-100"
>
  <header class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
    <p
      class="text-[11px] font-semibold uppercase tracking-[0.14em] text-gray-500 dark:text-gray-500 leading-tight tabular-nums"
    >
      <span>{fromLabel}</span>
      <span class="mx-1.5 text-gray-300 dark:text-gray-700" aria-hidden="true">—</span>
      <span class={isOngoing ? "text-sky-700 dark:text-sky-300" : ""}>
        {toLabel}
      </span>
    </p>
  </header>

  <h3
    class="mt-2 text-[18px] md:text-[19px] font-semibold leading-tight text-gray-900 dark:text-white"
  >
    {data.position}
    {
      item.link ? (
        <>
          <span
            class="mx-2 text-gray-300 dark:text-gray-700 font-normal"
            aria-hidden="true"
          >
            ·
          </span>
          <a
            href={item.link}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1 text-sky-700 dark:text-sky-300 hover:text-sky-900 dark:hover:text-sky-100 transition-colors duration-300"
          >
            <span>{data.place}</span>
            <Icon name="mdi:arrow-top-right" class="text-[14px]" />
          </a>
        </>
      ) : (
        <>
          <span
            class="mx-2 text-gray-300 dark:text-gray-700 font-normal"
            aria-hidden="true"
          >
            ·
          </span>
          <span class="text-sky-700 dark:text-sky-300">{data.place}</span>
        </>
      )
    }
  </h3>

  <p
    class="mt-3 text-[15px] leading-[1.7] text-gray-600 dark:text-gray-400 max-w-[62ch]"
  >
    {data.description}
  </p>

  {
    item.tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1.5 text-[12px] font-medium text-sky-700 dark:text-sky-300">
        {item.tags.map((tag) => (
          <li class="inline-flex items-center gap-1.5">
            <span
              class="inline-block h-1 w-1 rounded-full bg-sky-700/60 dark:bg-sky-300/50"
              aria-hidden="true"
            />
            <span>{tag}</span>
          </li>
        ))}
      </ul>
    )
  }
</article>
