---
import SectionHeading from "./SectionHeading.astro";
import type { Translations } from "../i18n/types";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="faq"
  class="py-10 md:py-14 scroll-mt-12"
  data-fade-on-scroll
  aria-labelledby="faq-heading"
>
  <SectionHeading id="faq-heading" label={t.faq.label} />

  <dl class="mt-8 flex flex-col divide-y divide-gray-200 dark:divide-slate-800">
    {
      t.faq.items.map((item) => (
        <div class="grid grid-cols-1 gap-2 md:grid-cols-[14rem_1fr] lg:grid-cols-[16rem_1fr] md:gap-x-8 py-5">
          <dt class="text-[14px] md:text-[15px] font-semibold leading-snug text-gray-900 dark:text-white">
            {item.q}
          </dt>
          <dd class="text-[15px] md:text-[16px] leading-[1.65] text-gray-600 dark:text-gray-400 max-w-[68ch]">
            {item.a}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
