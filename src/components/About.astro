---
import type { Translations } from "../i18n/types";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section
  id="about"
  data-section="about"
  class="py-12 md:py-16 scroll-mt-12"
  data-fade-on-scroll
>
  <SectionHeading label={t.about} />

  <div
    class="flex flex-col gap-5 mt-8 md:text-[16px] text-[15px] leading-[1.7] dark:text-gray-400 text-gray-600 max-w-[65ch]"
    set:html={t.aboutContent}
  >
  </div>
</section>
